#!/usr/bin/env bash
# Cut a release candidate by tagging the current HEAD of main.
# Computes the next rc counter from existing tags (unique regardless of main's
# current dev release number -- no need to bump that first), sets pyproject.toml
# to X.Y.Z-rc.N in a worktree, and pushes the tag — triggering publish-test.yml.
# Uses a git worktree so the dev's working directory is never modified.
# Finally waits for that workflow to finish and reports its outcome.
#
# Usage: cut-rc [--force]
#   --force  overwrite an existing tag (allows retrying a failed publish)
set -euo pipefail

if ! command -v gh >/dev/null 2>&1; then
    echo "error: gh CLI not found in PATH — run bin/install-gh-cli, or open a new terminal if you just installed it" >&2
    exit 1
fi

FORCE=0
if [[ "${1:-}" == "--force" ]]; then
    FORCE=1
fi

if ! git diff --quiet || ! git diff --cached --quiet; then
    echo "error: working tree has uncommitted changes — commit or stash first" >&2
    exit 1
fi

if [[ "$(git branch --show-current)" != "main" ]]; then
    echo "error: cut-rc must be run on main" >&2
    exit 1
fi

git fetch --force --tags origin main

LOCAL_SHA=$(git rev-parse HEAD)
REMOTE_SHA=$(git rev-parse origin/main)
if [[ "$LOCAL_SHA" != "$REMOTE_SHA" ]]; then
    echo "error: local main ($LOCAL_SHA) is not in sync with origin/main ($REMOTE_SHA) — pull/rebase (and push, if you have local commits) first" >&2
    exit 1
fi

eval "$(pdm run python - <<'PY'
import re, subprocess, sys

with open("pyproject.toml") as f:
    text = f.read()

vm = re.search(r'^version\s*=\s*"([^"]*)"', text, re.MULTILINE)
if not vm:
    sys.exit("version= line not found in pyproject.toml")
current = vm.group(1)

m = re.fullmatch(r"(\d+)\.(\d+)\.(\d+)-dev\.(\d+)", current)
if not m:
    sys.exit(f"expected X.Y.Z-dev.N in pyproject.toml, got: {current!r}")

x, y, z = int(m.group(1)), int(m.group(2)), int(m.group(3))
xyz = f"{x}.{y}.{z}"

tags = subprocess.check_output(["git", "tag", "--list", f"v{xyz}-rc.*"]).decode().split()
ns = [int(re.search(r"rc\.(\d+)$", t).group(1)) for t in tags if re.search(r"rc\.(\d+)$", t)]
n = max(ns) + 1 if ns else 1
new = f"{xyz}-rc.{n}"

nm = re.search(r'^name\s*=\s*"([^"]*)"', text, re.MULTILINE)
if not nm:
    sys.exit("name= line not found in pyproject.toml")
package_name = nm.group(1)

remote = subprocess.check_output(["git", "remote", "get-url", "origin"]).decode().strip()
rm = re.search(r'github\.com[:/](.+?)(?:\.git)?$', remote)
if not rm:
    sys.exit(f"could not parse GitHub repo from remote: {remote!r}")
github_repo = rm.group(1)

print(f"version: {current} → {new}", file=sys.stderr)
print(f"RC_VERSION={new}")
print(f"PACKAGE_NAME={package_name}")
print(f"GITHUB_REPO={github_repo}")
PY
)"

if git rev-parse "v$RC_VERSION" >/dev/null 2>&1; then
    if [[ "$FORCE" -eq 0 ]]; then
        echo "error: tag v$RC_VERSION already exists — use --force to overwrite" >&2
        exit 1
    fi
    echo "warning: overwriting existing tag v$RC_VERSION" >&2
fi

TMP=$(mktemp -d)
trap 'git worktree remove --force "$TMP" 2>/dev/null; rm -rf "$TMP"' EXIT

git worktree add --detach "$TMP" HEAD

pdm run python - "$RC_VERSION" "$PACKAGE_NAME" "$GITHUB_REPO" "$TMP/pyproject.toml" "$TMP/README.md" <<'PY'
import re, sys
new, package_name, github_repo, toml_path, readme_path = sys.argv[1:6]

with open(toml_path) as f:
    text = f.read()
updated = re.sub(r'^(version\s*=\s*")[^"]*(")', rf'\g<1>{new}\2', text, flags=re.MULTILINE)
assert updated != text, "version= line not found in pyproject.toml"
source_url = f"https://github.com/{github_repo}/tree/v{new}"
updated = re.sub(r'^(Source\s*=\s*")[^"]*(")', rf'\g<1>{source_url}\2', updated, flags=re.MULTILINE)
with open(toml_path, "w") as f:
    f.write(updated)

pypi_ver = re.sub(r"-rc\.", "rc", new)
pypi_url = f"https://test.pypi.org/project/{package_name}/{pypi_ver}/"
badge_url = f"https://img.shields.io/badge/pypi-v{pypi_ver}-blue.svg"
python_badge = "https://img.shields.io/badge/python-3.10%20|%203.11%20|%203.12%20|%203.13%20|%203.14-blue.svg"
ci_badge = "https://img.shields.io/badge/CI-passing-brightgreen.svg"
with open(readme_path) as f:
    readme = f.read()
readme = re.sub(r'\[!\[PyPI version\]\([^)]*\)\]\([^)]*\)',
                f'[![PyPI version]({badge_url})]({pypi_url})', readme)
readme = re.sub(r'\[!\[Python versions\]\([^)]*\)\]\([^)]*\)',
                f'[![Python versions]({python_badge})](https://pypi.org/project/{package_name}/)', readme)
readme = re.sub(r'\[!\[CI\]\([^)]*\)\]\([^)]*\)',
                f'[![CI]({ci_badge})](https://github.com/{github_repo}/actions/workflows/ci.yml)', readme)
with open(readme_path, "w") as f:
    f.write(readme)
PY

# Prepend an unreleased CHANGELOG entry if one doesn't already exist. The heading is a
# version-independent sentinel, not the rc/prod version -- cut-prod fills that in (along with
# the date) when it promotes this rc, so there's no version string here that could ever drift
# out of sync with pyproject.toml's.
pdm run python - "$TMP/CHANGELOG.md" <<'PY'
import re, sys
path = sys.argv[1]
with open(path) as f:
    text = f.read()
header = "## {{UNRELEASED}}"
if header not in text:
    entry = f"{header}\n\n- _Add release notes here._\n\n"
    text = re.sub(r"^(# CHANGELOG\n+)", rf"\1{entry}", text)
    with open(path, "w") as f:
        f.write(text)
# Non-blocking: an rc is disposable/iterative and only reaches TestPyPI, not the permanent
# record, so this is just an early heads-up -- cut-prod hard-blocks on the same thing later.
# Checks the unreleased section's own body specifically (is it *exactly* the placeholder?),
# not a substring search over the whole file -- otherwise this would false-positive on prose
# elsewhere (e.g. this very comment, or CHANGELOG.md text documenting the placeholder itself)
# that happens to quote the placeholder string without actually being an unfilled entry.
m = re.search(r"^## \{\{UNRELEASED\}\}\n(.*?)(?=^## |\Z)", text, re.MULTILINE | re.DOTALL)
if m and m.group(1).strip() == "- _Add release notes here._":
    print("warning: CHANGELOG.md's unreleased entry is still just cut-rc's placeholder -- "
          "write real release notes before cutting a production release.", file=sys.stderr)
PY

git -C "$TMP" add pyproject.toml CHANGELOG.md README.md
git -C "$TMP" commit -m "chore: release $RC_VERSION"
RC_SHA=$(git -C "$TMP" rev-parse HEAD)

if [[ "$FORCE" -eq 1 ]]; then
    git -C "$TMP" tag -f "v$RC_VERSION"
    git push --force origin "v$RC_VERSION"
else
    git -C "$TMP" tag "v$RC_VERSION"
    git push origin "v$RC_VERSION"
fi

# Wait for the triggered Publish TestPyPI workflow and report its outcome. Unlike
# cut-prod there's nothing to sync locally afterward -- this workflow only ever
# updates the rc-latest tag, never main. Identify the run by its head commit SHA,
# not `gh run list --branch` -- that flag isn't reliable for tag-triggered runs
# (it filters on branch refs, not tag refs). Errors from `gh` are allowed to print
# (not silenced) so an auth/API problem is visible instead of just "not found".
# If no run has matched by SHA halfway through, fall back to the most recently
# created run for this workflow -- for a solo/small-team repo, the newest run of
# a workflow we just triggered is almost certainly the one we're waiting on.
echo "Waiting for the Publish TestPyPI workflow to start..." >&2
RUN_ID=""
for attempt in $(seq 1 30); do
    RUN_ID=$(gh run list --workflow=publish-test.yml --json databaseId,headSha --limit 20 \
        --jq "[.[] | select(.headSha == \"$RC_SHA\")] | .[0].databaseId // empty") || true
    if [[ -n "$RUN_ID" ]]; then
        echo "Found run $RUN_ID for commit $RC_SHA." >&2
        break
    fi
    if [[ "$attempt" -eq 15 ]]; then
        FALLBACK_ID=$(gh run list --workflow=publish-test.yml --json databaseId --limit 1 --jq '.[0].databaseId // empty') || true
        if [[ -n "$FALLBACK_ID" ]]; then
            echo "No run matched commit $RC_SHA after $attempt attempts — falling back to the most recently created run for this workflow: $FALLBACK_ID" >&2
            RUN_ID="$FALLBACK_ID"
            break
        fi
    fi
    sleep 2
done

if [[ -z "$RUN_ID" ]]; then
    echo "warning: could not find the triggered Publish TestPyPI workflow run — check GitHub Actions manually" >&2
    exit 0
fi

echo "Watching run $RUN_ID..." >&2
if gh run watch "$RUN_ID" --exit-status; then
    echo "Publish TestPyPI succeeded for v$RC_VERSION." >&2
else
    echo "error: Publish TestPyPI workflow failed — see the run above for details" >&2
    exit 1
fi
