#!/bin/bash

set -euo pipefail

TEMPLATE_SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
TEMPLATE_PROJECT_ROOT=$( cd -- "$TEMPLATE_SCRIPT_DIR/.." &> /dev/null && pwd )

if [ -n "${1:-}" ]; then
    PROJECT_ROOT="$1"
else
    # Get the current git repo top-level directory
    PROJECT_ROOT=$(git rev-parse --show-toplevel)
fi
SCRIPT_DIR="$PROJECT_ROOT/bin"

cd "$PROJECT_ROOT"

"$TEMPLATE_SCRIPT_DIR/install-gh-cli"
"$SCRIPT_DIR/install-github-environments"

if [ -f "$PROJECT_ROOT/.template-vars-applied" ]; then
    echo "Project already initialized from template.  Skipping." >&2
else
    # Set up a brand new project
    "$TEMPLATE_SCRIPT_DIR/template-vars" --apply

    git add .
    git commit -m "Initial commit after applying project template variables"
fi

# Set up local project environment
"$SCRIPT_DIR/install"
