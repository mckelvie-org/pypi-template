#!/usr/bin/env python3
"""
This script creates a new github project from the project template, and initializes a local
repo from it.
"""

from __future__ import annotations

import json
import os
import re
import subprocess
import sys
from argparse import ArgumentParser
from pathlib import Path
from typing import TYPE_CHECKING
from urllib.error import HTTPError, URLError
from urllib.request import Request, urlopen

if TYPE_CHECKING:
    # typing.TypeAlias requires Python 3.10+; this script must also run under the
    # system Python 3.9 that bootstraps the project before a venv exists, so the
    # import is type-checking-only (annotations are never evaluated at runtime,
    # since `from __future__ import annotations` is in effect).
    pass

template_script_dir = Path(__file__).parent.resolve()
template_project_dir = template_script_dir.parent.resolve()
template_dir = template_project_dir / "src"
template_project_url = "git@github.com:mckelvie-org/pypi-template.git"

def normalize_pypi_name(name: str) -> str:
    """Normalize a project name per PEP 503, for comparison against index names."""
    return re.sub(r"[-_.]+", "-", name).lower()

def pypi_project_exists(project_name: str, index_label: str, index_url: str) -> bool:
    """Check whether a project name is already registered on a PyPI-compatible index.
    Network failures are treated as inconclusive (warn and assume not taken) rather than
    blocking project creation."""
    normalized = normalize_pypi_name(project_name)
    url = f"{index_url}/pypi/{normalized}/json"
    request = Request(url, method="HEAD")
    try:
        with urlopen(request, timeout=10) as response:
            return response.status == 200
    except HTTPError as e:
        if e.code == 404:
            return False
        print(f"warning: could not check {index_label} for existing project '{project_name}': HTTP {e.code}", file=sys.stderr)
        return False
    except URLError as e:
        print(f"warning: could not check {index_label} for existing project '{project_name}': {e}", file=sys.stderr)
        return False

def main() -> None:
    parser = ArgumentParser(description="Create a new project from the template.")
    parser.add_argument(
        "project_dir",
        help="The local repo directory to create (e.g. '../my-new-project').",
    )
    parser.add_argument(
        "--owner", "-o",
        help="The name of the github owner or organization for the repo. Defaults to the current gh login.",
        default=None,
    )
    parser.add_argument(
        "--project-name", "-p",
        help="The name of the new project. Defaults to the basename of the project directory.",
        default=None,
    )
    parser.add_argument(
        "--description",
        help="A short description of the new project. Defaults to \"Python package <project_name>\".",
        default=None,
    )
    parser.add_argument(
        "--ignore-existing-pypi-project",
        action="store_true",
        help="Skip the check for an existing project of the same name on PyPI/TestPyPI. "
             "Use this if you already own the name or have already configured a trusted publisher.",
    )
    args = parser.parse_args()
    
    subprocess.run([ str(template_script_dir / "install-gh-cli") ], check=True)
    project_dir: Path = Path(args.project_dir).expanduser().resolve()
    project_name: str = args.project_name or project_dir.name
    project_description: str = args.description or f"Python package {project_name}"
    owner: str | None = args.owner
    if owner is None:
        # Get the current github login
        result = subprocess.run(
            ["gh", "api", "user", "--jq", ".login"],
            capture_output=True,
            text=True,
        )
        if result.returncode != 0:
            raise RuntimeError("Failed to get current github login. Please specify --owner.")
        owner = result.stdout.strip()

    # Validate project name
    if not re.match(r"^[a-z0-9-]+$", project_name):
        raise ValueError(
            f"Project name must be lowercase and can only contain letters, numbers, and hyphens: '{project_name!r}'"
        )

    if not args.ignore_existing_pypi_project:
        for index_label, index_url in (("PyPI", "https://pypi.org"), ("TestPyPI", "https://test.pypi.org")):
            if pypi_project_exists(project_name, index_label, index_url):
                raise ValueError(
                    f"A project named '{project_name}' already exists on {index_label}. "
                    "Choose a different --project-name, or pass --ignore-existing-pypi-project "
                    "if you already own this name or have already configured a trusted publisher."
                )

    # Create the new project directory
    if project_dir.exists():
        raise FileExistsError(f"The directory '{project_dir}' already exists.")
    
    # if the directory is anywhere under an existing github repo, we should not create a new repo there
    current_dir = project_dir
    while current_dir != current_dir.parent:
        if (current_dir / ".git").exists():
            raise FileExistsError(
                f"The directory '{project_dir}' is under an existing git repo at '{current_dir}'."
            )
        current_dir = current_dir.parent
        
    # create a local github repo to hold the project
    os.makedirs(project_dir)
    os.chdir(project_dir)
    
    subprocess.run(["git", "init", "-b", "main", str(project_dir)], check=True)
        
    # Copy everything from the template directory to the new project directory, except for .git and
    # anything that is .gitignored.
    
    git_ls_output = subprocess.run(
        ["git", "-C", str(template_dir), "ls-files", "--cached", "--others", "--exclude-standard"],
        cwd=template_dir,
        capture_output=True,
        text=True,
        check=True,
    ).stdout
    filenames = [line.strip() for line in git_ls_output.splitlines() if line.strip()]
    
    for filename in filenames:
        src_path = template_dir / filename
        dest_path = project_dir / filename
        dest_dir = dest_path.parent
        os.makedirs(dest_dir, exist_ok=True)
        subprocess.run(["rsync", "-a", str(src_path), str(dest_path)], check=True)
        
    template_vars = {
        "PYTHON_PACKAGE": project_name,
        "PYTHON_MODULE": project_name.replace("-", "_"),
        "PROJECT_DESCRIPTION": project_description,
        "GITHUB_PROJECT_NAME": project_name,
        "GITHUB_OWNER_NAME": owner,
    }
    
    with open(project_dir / ".template-vars.json", "w") as f:
        json.dump(template_vars, f, indent=2, sort_keys=True)
    
    # resolve additional template variables in the new project directory
    subprocess.run([str(template_script_dir / "template-vars")], check=True)
    
    # apply the template variables to the new project directory
    subprocess.run([str(template_script_dir / "template-vars"), "--apply"], check=True)
    
    # Commit the changes to the new project repo
    subprocess.run(["git", "add", "."], check=True)
    subprocess.run(["git", "commit", "-m", "Initial commit from template"], check=True)
    
    # Create the github repo and push the local repo to it
    subprocess.run(
            [
                    "gh",
                    "repo",
                    "create",
                    f"{owner}/{project_name}",
                    "--public",
                    "--source=.",
                    "--remote=origin",
                    "--push"
                ],
            check=True
        )
    
    # Initialize the github environment, etc., and initialize the local dev environment
    subprocess.run([str(template_script_dir / "init-new-project")], check=True)
    
    print(f"New project '{project_name}' created successfully.")

if __name__ == "__main__":
    main()
